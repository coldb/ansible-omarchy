#!/usr/bin/env python3
import json
import shutil
import socket
import subprocess
import time


HOST = "127.0.0.1"
PORT = 5829
RECONNECT_DELAY_SECONDS = 1
NOTIFICATION_ID = "5829"
KANATA_KEYBOARD_DEVICE = "kanata"

LAYERS = {
    "us": ("  US ", "us", "US"),
    "nomods": ("  US ", "us", "US"),
    "estonian": ("  ET ", "estonian", "Estonian"),
    "numbers": ("  123", "numbers", "Numbers"),
    "symbols": ("  SYM", "symbols", "Symbols"),
}
NOTIFICATION_LAYERS = {"us", "estonian"}
XKB_LAYOUT_IDS = {
    "us": "0",
    "estonian": "1",
    "numbers": "0",
    "symbols": "0",
}

current_layer = "us"
last_persistent_layer = "us"
initialized = False
last_emit = None


def emit(layer, connected=True):
    global last_emit

    text, css_class, label = LAYERS.get(layer, (layer, "unknown", layer))
    if not connected:
        text = ""
        css_class = "hidden"
        label = "Unavailable"

    next_emit = (text, css_class, label)
    if next_emit == last_emit:
        return

    last_emit = next_emit
    print(
        json.dumps(
            {
                "text": text,
                "class": css_class,
                "tooltip": f"Keyboard layer: {label}",
            }
        ),
        flush=True,
    )


def notify(layer):
    if (
        not initialized
        or layer not in NOTIFICATION_LAYERS
        or not shutil.which("notify-send")
    ):
        return

    _, _, label = LAYERS.get(layer, (layer, "unknown", layer))
    subprocess.run(
        [
            "notify-send",
            "--app-name=Kanata",
            "--replace-id",
            NOTIFICATION_ID,
            "Keyboard layer",
            label,
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def switch_xkb_layout(layer):
    layout_id = XKB_LAYOUT_IDS.get(layer)
    if layout_id is None or not shutil.which("hyprctl"):
        return

    subprocess.run(
        ["hyprctl", "switchxkblayout", KANATA_KEYBOARD_DEVICE, layout_id],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def set_layer(layer):
    global current_layer, initialized, last_persistent_layer

    if layer == "nomods":
        return

    changed = layer != current_layer
    current_layer = layer
    emit(layer)
    switch_xkb_layout(layer)

    persistent_changed = layer in NOTIFICATION_LAYERS and layer != last_persistent_layer
    if changed and persistent_changed:
        last_persistent_layer = layer
        notify(layer)

    initialized = True


def handle_event(event):
    if "CurrentLayerName" in event:
        set_layer(event["CurrentLayerName"]["name"])
    elif "LayerChange" in event:
        set_layer(event["LayerChange"]["new"])


emit(current_layer, connected=False)

while True:
    try:
        with socket.create_connection((HOST, PORT), timeout=5) as sock:
            sock.settimeout(None)
            sock.sendall(b'{"RequestCurrentLayerName":{}}\n')
            with sock.makefile("r", encoding="utf-8", errors="replace") as stream:
                for line in stream:
                    try:
                        handle_event(json.loads(line))
                    except (json.JSONDecodeError, KeyError, TypeError):
                        continue
    except OSError:
        emit(current_layer, connected=False)
        time.sleep(RECONNECT_DELAY_SECONDS)
