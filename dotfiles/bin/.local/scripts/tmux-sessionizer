#!/usr/bin/env bash
# Initialize variable to store combined results
selected=""

if [[ $# -eq 1 ]]; then
    selected=$1
else
    if [ -f "$HOME/work/.local/scripts/tmux-sessionizer-files.sh" ]; then
        script_output=$( "$HOME/work/.local/scripts/tmux-sessionizer-files.sh" | tr " " "\n") 
        selected="$selected\n$script_output"
    fi

    if [ -f "$HOME/personal/.local/scripts/tmux-sessionizer-files.sh" ]; then
        script_output=$( "$HOME/personal/.local/scripts/tmux-sessionizer-files.sh" | tr " " "\n") 
        selected="$selected\n$script_output"
    fi

    selected=$(echo -e "$selected\n$(find ~/ ~/work/ ~/personal/ ~/worktree/ -mindepth 1 -maxdepth 1 -type d 2> /dev/null)" | grep -v '^$'| fzf --tac --info=hidden)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected
    exit 0
fi

if ! tmux has-session -t=$selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

tmux switch-client -t $selected_name
