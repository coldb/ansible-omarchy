#!/bin/bash

# Define available tags. Mark with :vault if --ask-vault-pass is needed.
tags=(
  "install:vault"
  "install-ai"
  "install-brave"
  "install-browsers"
  "install-chrome"
  "install-claude-code"
  "install-cursor"
  "install-firefox"
  "install-flux"
  "install-k8s-tools"
  "install-k9s"
  "install-kubectl"
  "install-pgcli"
  "install-ssh:vault"
  "install-thunderbird"
  "install-tmux"
  "install-zsh"
  "setup"
  "update:vault"
  "update-ai"
  "update-brave"
  "update-browsers"
  "update-chrome"
  "update-claude-code"
  "update-cursor"
  "update-firefox"
  "update-flux"
  "update-k8s-tools"
  "update-k9s"
  "update-kubectl"
  "update-pgcli"
  "update-ssh:vault"
  "update-thunderbird"
  "update-tmux"
  "update-zsh"
)

# ---

all_tags=()
vault_tags=()

for entry in "${tags[@]}"; do
  tag="${entry%%:*}"
  all_tags+=("$tag")
  if [[ "$entry" == *":vault" ]]; then
    vault_tags+=("$tag")
  fi
done

verbosity=""
if [[ "$1" =~ ^-v{1,4}$ ]]; then
  verbosity="$1"
  shift
fi

if [ -n "$1" ]; then
  requested_tags="$1"
  shift
else
  fzf_list=()
  for entry in "${tags[@]}"; do
    tag="${entry%%:*}"
    if [[ "$entry" == *":vault" ]]; then
      fzf_list+=("$tag (vault)")
    else
      fzf_list+=("$tag")
    fi
  done

  selected_entries=$(printf '%s\n' "${fzf_list[@]}" | fzf --multi --prompt="Select tags: ")

  if [ -z "$selected_entries" ]; then
    echo "No tags selected."
    exit 1
  fi

  requested_tags=$(echo "$selected_entries" | sed 's/ (vault)//g' | paste -sd,)
fi

needs_vault=false
IFS=',' read -ra selected <<< "$requested_tags"
for sel in "${selected[@]}"; do
  for vt in "${vault_tags[@]}"; do
    if [[ "$sel" == "$vt" ]]; then
      needs_vault=true
      break 2
    fi
  done
done

extra_flags=()
if $needs_vault; then
  extra_flags+=("--ask-vault-pass")
fi

ansible-galaxy collection install -r ansible/collections/requirements.yaml

ansible-playbook ansible/local.yaml -i ansible/inventory.ini --tags "$requested_tags" --ask-become-pass ${verbosity} "${extra_flags[@]}" "$@"
