#!/bin/bash
cd "$(dirname "$0")"

personal_dir="$HOME/personal/ansible-omarchy-personal"
if [ -d "$personal_dir" ]; then
  choice=$(printf 'general\npersonal\n' | fzf --prompt="Select playbook: ")
  if [ -z "$choice" ]; then
    echo "No playbook selected."
    exit 1
  fi
  if [ "$choice" = "personal" ]; then
    exec "$personal_dir/run" "$@"
  fi
fi

# Define available tags. Mark with :vault if --ask-vault-pass is needed.
tags=(
  "install-ai"
  "install-brave"
  "install-browsers"
  "install-chrome"
  "install-claude-code"
  "install-codex-cli"
  "install-cursor"
  "install-development"
  "install-docker-gpu-support"
  "install-firefox"
  "install-flux"
  "install-ghostty"
  "install-hyprland"
  "install-k8s-tools"
  "install-k9s"
  "install-keyboard"
  "install-kubectl"
  "install-laptop"
  "install-laptop-sound"
  "install-mise"
  "install-neovim"
  "install-personal"
  "install-pgcli"
  "install-ssh:vault"
  "install-t3code"
  "install-thunderbird"
  "install-tmux"
  "install-tools"
  "install-waybar"
  "install-zsh"
  "install:vault"
  "patch-browsers"
  "setup"
  "update-ai"
  "update-brave"
  "update-browsers"
  "update-chrome"
  "update-claude-code"
  "update-codex-cli"
  "update-cursor"
  "update-development"
  "update-docker-gpu-support"
  "update-firefox"
  "update-flux"
  "update-ghostty"
  "update-hyprland"
  "update-k8s-tools"
  "update-k9s"
  "update-keyboard"
  "update-kubectl"
  "update-laptop"
  "update-laptop-sound"
  "update-mise"
  "update-neovim"
  "update-personal"
  "update-pgcli"
  "update-ssh:vault"
  "update-t3code"
  "update-thunderbird"
  "update-tmux"
  "update-tools"
  "update-waybar"
  "update-zsh"
  "update:vault"
)

source ~/ansible-omarchy/lib/ansible-run.sh
