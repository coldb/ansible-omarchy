#!/bin/bash
cd "$(dirname "$0")"

personal_dir="$HOME/ansible-omarchy-personal"
if [ -d "$personal_dir" ]; then
  choice=$(printf 'general\npersonal\n' | fzf --prompt="Select playbook: ")
  if [ -z "$choice" ]; then
    echo "No playbook selected."
    exit 1
  fi
  if [ "$choice" = "personal" ]; then
    exec "$personal_dir/run" "$@"
  fi
fi

# Define available tags. Mark with :vault if --ask-vault-pass is needed.
tags=(
  "install:vault"
  "install-ai"
  "install-brave"
  "install-browsers"
  "install-chrome"
  "install-claude-code"
  "install-cursor"
  "install-development"
  "install-firefox"
  "install-flux"
  "install-ghostty"
  "install-hyprland"
  "install-k8s-tools"
  "install-k9s"
  "install-kubectl"
  "install-mise"
  "install-neovim"
  "install-pgcli"
  "install-ssh:vault"
  "install-thunderbird"
  "install-tmux"
  "install-zsh"
  "setup"
  "update:vault"
  "update-ai"
  "update-brave"
  "update-browsers"
  "update-chrome"
  "update-claude-code"
  "update-cursor"
  "update-development"
  "update-firefox"
  "update-flux"
  "update-ghostty"
  "update-hyprland"
  "update-k8s-tools"
  "update-k9s"
  "update-kubectl"
  "update-mise"
  "update-neovim"
  "update-pgcli"
  "update-ssh:vault"
  "update-thunderbird"
  "update-tmux"
  "update-zsh"
)

source ~/ansible-omarchy/lib/ansible-run.sh
